# Copy this file to secrets.toml and fill in your values.
# DO NOT commit secrets.toml to git — it should be in .gitignore.
#
# On Streamlit Community Cloud, set these in the app's Secrets UI instead
# (Settings → Secrets), not by committing this file.

neon_db = "postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
app_password = "your-strong-shared-password-here"

# Optional — controls what's shown on the dashboard UI.
# Kept in secrets so the public repo code stays free of personal info.
patient_name = "Patient"
patient_dx = ""
app_title = "Lab Tracker"
